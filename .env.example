# ===================================================
# ローカル開発用環境変数（.envにコピーして値を設定）
# Cloud Run上ではSecret Managerから自動読み込みされる
# ===================================================

# MySQL (Cloud SQL)
MYSQL_USER=uttc
MYSQL_PWD=your_password_here
MYSQL_HOST=tcp(your-cloud-sql-public-ip:3306)
MYSQL_DATABASE=hackathon

# JWT署名シークレット（本番は長いランダム文字列を使用）
JWT_SECRET=change_this_to_a_long_random_string

# Google Cloud Storage（画像アップロード先バケット名）
GCS_BUCKET=your-gcs-bucket-name

# Gemini API（商品説明生成・質問応答）
GEMINI_API_KEY=AIza...

# GCPサービスアカウントキー（ローカル開発時のみ。Cloud Runでは不要）
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# GCPプロジェクトID（Cloud Vision API・Secret Manager用）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# サーバーポート（Cloud Runが自動セット、ローカルは8080）
PORT=8080
